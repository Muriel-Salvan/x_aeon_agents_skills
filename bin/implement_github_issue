#!/usr/bin/env ruby

# Parameters:
# * *github_issue_number* (Integer): The Github issue number to implement
# * *run_id* (String): [Optional] The run ID for persistence
github_issue_number = Integer(ARGV[0])
run_id = ARGV[1]

require 'x_aeon_agents_skills'

XAeonAgentsSkills::Configuration.configure(**XAeonAgentsSkills::Helpers.keys_from_launcher)
XAeonAgentsSkills::Agents.implement_github_issue(github_issue_number, run_id:)
