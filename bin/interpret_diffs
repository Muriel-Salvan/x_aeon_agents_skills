#!/usr/bin/env ruby

# Parameters::
# * *base* (Object): Git base (sha, objectish...) with which we diff [default = 'HEAD']
base = ARGV[0] || 'HEAD'

require 'x_aeon_agents_skills'

XAeonAgentsSkills::Agents.configure(
  cline_api_key: Bundler.with_unbundled_env { `launcher safe -- "Cline API key"`.match(/\[PASSWORD\][^:]+: ([^\n]+)\n/)[1] },
  debug: true
)

XAeonAgentsSkills::Agents.interpret_diffs(base)
